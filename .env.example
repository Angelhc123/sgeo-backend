MONGO_URL=
# SECRET_KEY: declarada pero actualmente sin uso. No hay JWT ni validacion de sesion
# en el backend (solo auth/login verifica credenciales una vez). Ver routes/auth.py.
SECRET_KEY=
FIREBASE_CREDENTIALS_JSON=
PORT=8000
# ENV=development habilita CORS abierto (allow_origins=["*"]) para desarrollo local.
# Cualquier otro valor (o ausente) usa la lista restringida de origenes en main.py.
ENV=development
